struct Bucket {
    void* mem;      // List of chunks of memory
    ulong elems;    // # chunks available in this bucket
    ulong pages;    // # pages used for this bucket size
    ulong size;     // Size of this kind of chunk
}

private __gshared {
    Bucket[PAGE_SHIFT] buckets;
    long               in_kmalloc;
    aspace*            kernel_aspace;
    ulong              next_huge_vaddr;
}

