private int get_bucket( ulong n ) => log2[n - 1];

T*
kmalloc(T)( size_t size = T.sizeof ) {
    ulong addr;

    if( size == 0 )
        return null;

    in_kmalloc++;
    scope(exit) in_kmalloc--;

    if( size > PAGE_SIZE / 2 ) {
        auto pages = pages_num( size );
        auto length = pages << PAGE_SHIFT;

        ulong vaddr;
        auto ret = kernel_aspace.map( next_huge_vaddr, length, &vaddr, "HugeMalloc" );
        assert( ret == Status.Ok );
        next_huge_vaddr = vaddr + length;

        for( auto i = 0; i < pages; i++ ) {
            auto ppage = alloc_pageframe();
            auto page  = p2v(ppage << PAGE_SHIFT);
            auto pf    = v2pf( page );

            map_page( m.kernel_pml4, vaddr + (i << PAGE_SHIFT), ppage << PAGE_SHIFT, Page.Present | Page.Writable | Page.Global ); // RW
            pf.tag  = FrameType.HugeMalloc;
            pf.size = pages;
        }

        //ktrace!"kmalloc: huge alloc of %i bytes (%i pages) at vaddr 0x%x\n"(size, pages, vaddr);

        return cast(T*)vaddr;
    }

    auto bucket = get_bucket( size );
    auto b = &buckets[bucket];

    if( b.mem == null ){
        auto page       = p2v(alloc_pageframe() << PAGE_SHIFT);
        v2pf(page).tag  = FrameType.Malloc;
        v2pf(page).size = bucket;

        auto p = cast(ubyte*)page;
        for( auto i = 0; i < PAGE_SIZE; i += b.size ) {
            *(cast(ubyte**)(p+i)) = cast(ubyte*)b.mem;
            b.mem = p + i;
        }
        b.pages++;
    }

    addr = cast(ulong)b.mem;
    b.mem = *cast(void**)b.mem;

    memset(cast(void*)addr, 0, b.size);
    return cast(T*)addr;
}

T*
krealloc(T)( T* ptr, size_t new_size = T.sizeof ) {
    if( ptr == null )
        return kmalloc!T( new_size );

    auto t = v2pf(cast(ulong)ptr);

    if( t.tag != FrameType.Malloc ) {
        klog!"<Red>TODO</>krealloc: reallocating non-malloc pointer %x with tag %i\n"(ptr, t);
        return null;
    }

    auto old_bucket = t.size;
    auto old_size = buckets[old_bucket].size;

    if( new_size <= old_size )
        return ptr; // No need to reallocate

    auto new_ptr = kmalloc!T( new_size );
    if( new_ptr == null )
        return null; // OOM

    // Copy old data to new location
    memcpy( new_ptr, ptr, old_size );

    kfree(ptr);
    return new_ptr;
}

void
kfree( void* ptr ) {
    if( ptr == null ) {
        kpanic!"Null freed.\n";
    }

    PageFrame *t = v2pf(cast(ulong)ptr);
    //ktrace!"kfree: freeing pointer 0x%x with tag %i\n"(ptr, t.tag);

    if( t.tag == FrameType.Malloc ) {
        auto bucket = t.size;
        auto b = &buckets[bucket];

        *cast(void**)ptr = b.mem;
        b.mem = ptr;
    } else if( t.tag == FrameType.HugeMalloc ) {
        auto pages = pages_num( t.size << PAGE_SHIFT );

        for( auto i = 0; i < pages; i++ ) {
            auto vaddr = cast(ulong)ptr + (i << PAGE_SHIFT);
            auto paddr = v2p(m.kernel_pml4, vaddr);
            free_pageframe( paddr >> PAGE_SHIFT );
            unmap_page( m.kernel_pml4, vaddr );
            ktrace!"kfree: huge alloc unmapping page frame 0x%x from vaddr 0x%x\n"(paddr, vaddr);
        }
    } else {
        kdebug!"kfree: invalid pointer 0x%x with tag %i\n"(ptr, t);
    }
}

void
heap_init() {
    for( auto i = 0; i < PAGE_SHIFT; i++ ) {
        auto b = &buckets[i];
        b.size = 1 << i;
    }

    ulong result;
    kernel_aspace = as_create( KERNEL_SPACE_BASE, 0xFFFF_FFFF_FFFF_FFFF );
    kernel_aspace.map( cast(ulong)&__kernel_start, cast(ulong)&__kernel_end, &result, "Kernel" );

    kdebug!"Kernel space starts at 0x%x, image from 0x%x-0x%x (%i bytes)\n"(KERNEL_SPACE_BASE, cast(ulong)&__kernel_start, cast(ulong)&__kernel_end, cast(ulong)&__kernel_end - cast(ulong)&__kernel_start );

    //auto a1 = kmalloc!ulong(1024*1024);
    //kdebug!"Huge alloc: 1MiB at 0x%x\n"(a1);
}
